{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "aeco": ["dist/index.d.ts", "dist/index.js"],
      "aeco/*": ["dist/*"]
    }
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "dist/**/*.d.ts",
    "drawUI/**/*.js",
    "examples/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "external/dist",
    "external/vendor"
  ]
}
